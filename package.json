		"@tailwindcss/vite": "4.3.1",
		"@zxing/browser": "0.2.0",
		"@zxing/library": "0.22.0",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"idb-keyval": "6.2.5",
		"lucide-react": "1.20.0",
		"pako": "2.1.0",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"react-qr-code": "2.2.0",
		"shadcn": "4.11.0",
		"sonner": "2.0.7",
