		"@vitejs/plugin-react": "6.0.2",
		"commitizen": "4.3.2",
		"cz-git": "1.13.1",
		"husky": "9.1.7",
		"oxfmt": "0.55.0",
		"oxlint": "1.70.0",
		"release-it": "20.2.0",
		"typescript": "6.0.3",
		"vite": "8.0.16",
